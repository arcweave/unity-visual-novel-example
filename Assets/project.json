21-4509-93f7-8917927f14f7","29933839-35bd-49e2-b772-9fdd250729b2","b2a2f65d-99bf-4615-bdfa-3cda4ad3d599","325ea6e9-9ef6-4474-959a-8e3db56bcd7e","8d832456-ba83-47c4-b9e1-70768a119077","879ab048-45ec-45d9-b586-9662d9c69207","25ca072d-3add-465c-a514-7e463775a0cd","28699c0d-c12a-43cd-b106-a0cdf953dd1d","0ff0c333-9e2b-4a95-a62d-72710ae660ac","f62ad36b-c385-4455-8e90-2339c9d2ea5d","e1e007c6-9aff-4d02-ba4d-f0665330407b","1376d465-54bd-4fda-adde-a9a2231aed33","cd1d6393-3e08-4463-89d3-ed4d76b40280","2a903b36-d457-402d-a512-e8e3323c36bf","c4560a2e-1fed-478e-9935-6393902ce8e0","4ab6a842-4a58-4144-babb-fe76bee42ae0","51077c30-3bc3-427a-b1a1-8d6be26dc197","520395c4-13c3-44ce-b9e2-edca4d8818c6","bb8a62f6-111f-445f-bb20-cd7d99407510","1ae4f4ff-af0c-4eec-8dbe-c4512de310de","59c12c7d-a290-4264-a9fe-086ff970b102","98d5ea37-573b-4ca2-8ce6-c586b6b48eda","dd137f1f-0fcc-439b-8c4b-ac39c092d529","559939e2-76a5-43d1-a9bb-eb2e842c13ba"]},"b924f43d-3c3c-4769-b9c2-34a7a5c8da49":{"name":"Credits","notes":["e31f8c73-9d3a-43f2-a009-04a569b1c06b"],"jumpers":[],"branches":[],"elements":[],"connections":[]}},"notes":{"0467057c-543d-4a47-a30e-3e10951dea4e":{"x":9040,"y":11940,"theme":"lightBlue","width":301,"height":148,"content":"<p>This is a <a target=\"_blank\" rel=\"noopener noreferrer nofollow\" href=\"https:\/\/docs.arcweave.com\/project-items\/labels\"><strong>label<\/strong><\/a>. In <strong>Play Mode<\/strong>, it appears as a player option.<\/p><p>Labels can do more than this; they can also contain <a target=\"_blank\" rel=\"noopener noreferrer nofollow\" href=\"https:\/\/docs.arcweave.com\/project-items\/labels#arcscript-in-labels\">code<\/a>. But let's keep it simple for now.<\/p>","autoHeight":true},"137fd37b-86ce-4a02-8e8d-250172a3f0eb":{"x":7200,"y":11720,"theme":"lightBlue","width":321,"height":133,"content":"<p>The wide image (your scene's background) is an <a target=\"_blank\" rel=\"noopener noreferrer nofollow\" href=\"https:\/\/docs.arcweave.com\/project-items\/elements#setting-a-cover\"><strong>element cover<\/strong><\/a>. To add one, drag an <a target=\"_blank\" rel=\"noopener noreferrer nofollow\" href=\"https:\/\/docs.arcweave.com\/project-items\/assets\/images\"><strong>image asset<\/strong><\/a> from the <strong>Assets<\/strong> section (left sidebar) and drop it into the element.<\/p>","autoHeight":true},"145815ed-47d6-4eb9-9d58-9b88c47b1816":{"x":5840,"y":11160,"theme":"pink","width":301,"height":169,"content":"<p>Welcome! This tutorial will guide you through creating a <a target=\"_blank\" rel=\"noopener noreferrer nofollow\" href=\"https:\/\/en.wikipedia.org\/wiki\/Visual_novel\"><strong>visual novel<\/strong><\/a> in Arcweave.<\/p><p>For broader Arcweave fundamentals, check out the <strong>Interactive Fiction<\/strong> example in the <a target=\"_blank\" rel=\"noopener noreferrer nofollow\" href=\"https:\/\/docs.arcweave.com\/workspaces\/projects#project-templates\">project templates<\/a>.<\/p>","autoHeight":true},"33b1918d-9ffa-4695-8442-00475a7aa6d1":{"x":9800,"y":10900,"theme":"lightBlue","width":301,"height":148,"content":"<p>Notice how the audio changes here. The <em>school<\/em> audio stops and the <em>festival<\/em> one starts.<\/p><p>Click on the attached audio assets, to see their settings.<\/p>","autoHeight":true},"36b0f4e4-2344-489f-bca7-e7d44ec26c26":{"x":9820,"y":12500,"theme":"lightBlue","width":301,"height":148,"content":"<p>Notice how the audio changes here. The <em>school<\/em> audio stops and the <em>festival<\/em> one starts.<\/p><p>Click on the attached audio assets, to see their settings.<\/p>","autoHeight":true},"39c8d2fd-4e11-4a2d-971b-c972c7771dd0":{"x":6760,"y":11480,"theme":"lightBlue","width":301,"height":101,"content":"<p>Creating a connection is intuitive: drag from any edge of the source element and drop into the target.<\/p>","autoHeight":true},"3fd33728-d249-4683-a546-30bfcff6e6da":{"x":7200,"y":11880,"theme":"pink","width":321,"height":190,"content":"<p>The character images are <a target=\"_blank\" rel=\"noopener noreferrer nofollow\" href=\"https:\/\/docs.arcweave.com\/project-items\/components\"><strong>components<\/strong><\/a>. To attach a component, drag it from the <strong>Components<\/strong> section (also in the left sidebar) into the element.<\/p><p>To change the attached components' order, simply drag and drop them relative to each other.<\/p>","autoHeight":true},"424bb5db-dd45-417b-bdb7-c4a838760078":{"x":6280,"y":10980,"theme":"lightBlue","width":341,"height":101,"content":"<p>This is your story's starting <a target=\"_blank\" rel=\"noopener noreferrer nofollow\" href=\"https:\/\/docs.arcweave.com\/project-items\/elements\"><strong>element<\/strong><\/a>. Double click it to edit its title or content. (In <em>rich text,<\/em> too!)<\/p>","autoHeight":false},"4b662f1d-bdad-47c9-aad0-77cf6c313047":{"x":9180,"y":11300,"theme":"lightBlue","width":301,"height":148,"content":"<p>This is a <a target=\"_blank\" rel=\"noopener noreferrer nofollow\" href=\"https:\/\/docs.arcweave.com\/project-items\/labels\"><strong>label<\/strong><\/a>. In <strong>Play Mode<\/strong>, it appears as a player option.<\/p><p>Labels can do more than this; they can also contain <a target=\"_blank\" rel=\"noopener noreferrer nofollow\" href=\"https:\/\/docs.arcweave.com\/project-items\/labels#arcscript-in-labels\">code<\/a>. But let's keep it simple for now.<\/p>","autoHeight":true},"660685e7-83df-4ae2-83a3-856ec15d614e":{"x":7200,"y":11140,"theme":"lightBlue","width":321,"height":62,"content":"<p>Notice the images in the element below.<\/p>","autoHeight":false},"8fadad9b-50d9-486d-bb86-f4723fdc939d":{"x":5840,"y":11360,"theme":"lightBlue","width":301,"height":247,"content":"<p>To begin, press the <strong>Play (\u25b6\ufe0f)<\/strong> button in the top menu to enter <a target=\"_blank\" rel=\"noopener noreferrer nofollow\" href=\"https:\/\/docs.arcweave.com\/project-tools\/play-mode\/overview\"><strong>Play Mode<\/strong><\/a>.<\/p><p>If you\u2019ve played other Arcweave projects before, you\u2019ll already be familiar with Play Mode.<\/p><p>This project, however, makes use of the <a target=\"_blank\" rel=\"noopener noreferrer nofollow\" href=\"https:\/\/docs.arcweave.com\/project-tools\/play-mode\/style-editor\"><strong>Style Editor<\/strong><\/a> to create the classic visual novel look, instead of relying on Arcweave\u2019s default CSS.<\/p>","autoHeight":true},"9db8fd48-acc7-44fa-b8d2-430f8b45d78b":{"x":9480,"y":10340,"theme":"pink","width":301,"height":226,"content":"<p>To change a character's emotion and facial expression, you need to create a new component. <\/p><p>Set the desired image asset as the new component's cover.<\/p><p>Notice how this project uses different components for each characters <em>default<\/em> and <em>smile<\/em> expression.<\/p>","autoHeight":true},"b36627c6-29f3-4971-980c-a8d45c547f57":{"x":8980,"y":10800,"theme":"lightBlue","width":301,"height":148,"content":"<p>This is a <a target=\"_blank\" rel=\"noopener noreferrer nofollow\" href=\"https:\/\/docs.arcweave.com\/project-items\/labels\"><strong>label<\/strong><\/a>. In <strong>Play Mode<\/strong>, it appears as a player option.<\/p><p>Labels can do more than this; they can also contain <a target=\"_blank\" rel=\"noopener noreferrer nofollow\" href=\"https:\/\/docs.arcweave.com\/project-items\/labels#arcscript-in-labels\">code<\/a>. But let's keep it simple for now.<\/p>","autoHeight":true},"d23b9574-b3ae-4ca6-aaec-639879be8009":{"x":6760,"y":11340,"theme":"lightBlue","width":301,"height":101,"content":"<p>This is a <a target=\"_blank\" rel=\"noopener noreferrer nofollow\" href=\"https:\/\/docs.arcweave.com\/project-items\/connections\"><strong>connetion<\/strong><\/a>. Connect elements to create the flow of your story.<\/p>","autoHeight":true},"dea777b9-444a-44f6-b5c3-dee7a72e14ca":{"x":9800,"y":11760,"theme":"lightBlue","width":301,"height":148,"content":"<p>Notice how the audio changes here. The <em>school<\/em> audio stops and the <em>home<\/em> one starts.<\/p><p>Click on the attached audio assets, to see their settings.<\/p>","autoHeight":true},"e31f8c73-9d3a-43f2-a009-04a569b1c06b":{"x":10060,"y":10600,"theme":"pink","width":281,"height":141,"content":"<p><strong>Image Credits<\/strong><br>Characters by <a target=\"_blank\" rel=\"noopener noreferrer nofollow\" href=\"https:\/\/sutemo.itch.io\/\">Sutemo<\/a><\/p><p><strong>Music Credits<\/strong><br>Bg music by <a target=\"_blank\" rel=\"noopener noreferrer nofollow\" href=\"https:\/\/authorseo.itch.io\/visual-love-bgm-all-in-one-pack\">AuthorSeo<\/a><\/p>","autoHeight":false},"ef914b97-7f4c-4269-8a6a-3c7c73b20373":{"x":7640,"y":11720,"theme":"pink","width":321,"height":148,"content":"<p>Click on the attached component to <a target=\"_blank\" rel=\"noopener noreferrer nofollow\" href=\"https:\/\/docs.arcweave.com\/project-items\/components#editing-components\">edit it<\/a>.<\/p><p>You can change its name and cover (as well as add <a target=\"_blank\" rel=\"noopener noreferrer nofollow\" href=\"https:\/\/docs.arcweave.com\/project-items\/attributes\">attributes<\/a>, but let's leave this for another tutorial).<\/p>","autoHeight":true},"f1bddc47-bc2c-4942-842d-5359ac1fb039":{"x":6280,"y":11800,"theme":"lightBlue","width":341,"height":205,"content":"<p>Add audio to your elements so it plays during Play Mode.<\/p><p>To do this, drag an <a target=\"_blank\" rel=\"noopener noreferrer nofollow\" href=\"https:\/\/docs.arcweave.com\/project-items\/assets\/audio\"><strong>audio asset<\/strong><\/a> from the <a target=\"_blank\" rel=\"noopener noreferrer nofollow\" href=\"https:\/\/docs.arcweave.com\/project-items\/assets\/overview\"><strong>Assets<\/strong><\/a> section in the left sidebar and drop it into the element.<\/p><p>Click on the attached audio asset to set its behavior: play once, loop, or stop.<\/p>","autoHeight":true}},"elements":{"334bdef8-c6ae-464e-8c90-03bc5835cef9":{"x":10460,"y":10320,"theme":"purple","width":301,"assets":{"cover":{"id":"7981bafc-4fcc-4780-99c8-99bd95c293d7"}},"height":226,"outputs":["b2a2f65d-99bf-4615-bdfa-3cda4ad3d599"],"autoHeight":true,"components":["ad3d9699-c9ea-4bc0-aa9f-e9656ca0791c"],"content":"<p><strong>Maya:<\/strong> \"See? This is exactly what we needed! Sometimes you have to live a little!\"<\/p>","title":null},"34a6a960-a808-4562-ad24-55a90a1d0e9b":{"x":11420,"y":12240,"theme":"blue","width":301,"assets":{"cover":{"id":"b6f13187-fd33-415a-828f-38343a856f98"}},"height":121,"outputs":["f62ad36b-c385-4455-8e90-2339c9d2ea5d"],"autoHeight":true,"components":["894c2a71-952e-45c9-b55a-340794307a1d"],"content":"<p><strong>Jake:<\/strong> \"See? Balance is everything.\"<\/p>","title":null},"35533a31-2b6e-4cf2-9bf9-a904836fc398":{"x":7640,"y":11240,"theme":"cyan","width":321,"assets":{"cover":{"id":"7801bdd7-f722-44d4-9a4b-d1d16e048586"}},"height":421,"outputs":["7c41bd83-ae2c-4ff0-b06d-5293676935c3"],"autoHeight":true,"components":["ad3d9699-c9ea-4bc0-aa9f-e9656ca0791c"],"content":"<p><strong>Maya:<\/strong> \"Alex! Perfect timing! There's this amazing street festival downtown tonight. Live music, food trucks, the works! We should totally go!\"<\/p>","title":"<p>Maya's Invitation<\/p>"},"56d29f34-94f8-42fe-a71f-302938329f34":{"x":10440,"y":11340,"theme":"orange","width":301,"assets":{"cover":{"id":"b6f13187-fd33-415a-828f-38343a856f98"}},"height":121,"outputs":["25ca072d-3add-465c-a514-7e463775a0cd"],"autoHeight":true,"components":["894c2a71-952e-45c9-b55a-340794307a1d"],"content":"<p><strong>Jake:<\/strong> \"Sometimes the best adventures happen right at home, you know?\"<\/p>","title":null},"5d00bdb7-a34f-49e5-ad42-a7373f72f7f0":{"x":8540,"y":11300,"theme":"cyan","width":301,"assets":{"cover":{"id":"7801bdd7-f722-44d4-9a4b-d1d16e048586"}},"height":161,"outputs":["520395c4-13c3-44ce-b9e2-edca4d8818c6","bb8a62f6-111f-445f-bb20-cd7d99407510","1ae4f4ff-af0c-4eec-8dbe-c4512de310de"],"autoHeight":true,"components":[],"content":"<p>You look between your two friends, each offering exactly what they love most. After this exhausting week, what do you really need?<\/p>","title":null},"714a2e99-b0e7-4b7f-b4fd-7fcebc821e05":{"x":8080,"y":11240,"theme":"cyan","width":301,"assets":{"cover":{"id":"7801bdd7-f722-44d4-9a4b-d1d16e048586"}},"height":161,"outputs":["d1c1c0ad-fe9d-467b-aee5-d885fdb0a82c"],"autoHeight":true,"components":["894c2a71-952e-45c9-b55a-340794307a1d"],"content":"<p><strong>Jake:<\/strong> \"Or... we could have a chill movie marathon at my place. I got that new sci-fi series everyone's talking about. Pizza, comfy couch, no crowds.\"<\/p>","title":"<p>Jake's Invitation<\/p>"},"72e86a62-a245-42b3-92b8-5d0dec45ff5d":{"x":11660,"y":11560,"theme":"orange","width":301,"assets":{"cover":{"id":"b6f13187-fd33-415a-828f-38343a856f98"}},"height":140,"outputs":["e1e007c6-9aff-4d02-ba4d-f0665330407b"],"autoHeight":true,"components":["894c2a71-952e-45c9-b55a-340794307a1d"],"content":"<p><strong>Jake:<\/strong> \"Deal. But tonight was exactly what we needed to recharge for the next adventure.\" <\/p>","title":null},"748f87cb-73cf-4c48-8b48-a91cae201546":{"x":10940,"y":10360,"theme":"purple","width":301,"assets":{"cover":{"id":"7981bafc-4fcc-4780-99c8-99bd95c293d7"}},"height":140,"outputs":["325ea6e9-9ef6-4474-959a-8e3db56bcd7e","8d832456-ba83-47c4-b9e1-70768a119077"],"autoHeight":true,"components":[],"content":"<p><em>Maya's enthusiasm is infectious, but you can feel the week's fatigue still weighing on your shoulders.<\/em><\/p>","title":null},"787b1285-f5d5-4d48-97af-c2a526d6c024":{"x":9820,"y":12040,"theme":"blue","width":301,"assets":{"audio":[{"id":"6644bfbf-9db5-4027-b9f8-73c23527b91f","mode":"loop","asset":"588547a5-1c12-41bb-9596-2712de1dcf24","delay":0},{"id":"85a6d2b3-45bc-45ce-b5ae-6066677063ec","mode":"stop","asset":"caa99cda-776d-4bc0-a80d-72f0326f648a","delay":0}],"cover":{"id":"7981bafc-4fcc-4780-99c8-99bd95c293d7"}},"height":121,"outputs":["dd137f1f-0fcc-439b-8c4b-ac39c092d529"],"autoHeight":true,"components":[],"content":"<p>Two hours at the festival gave you the energy boost you needed.<\/p>","title":"<p>Best of Both Worlds<\/p>"},"7886024f-0500-45ed-ba40-f917f91309ff":{"x":9800,"y":10340,"theme":"purple","width":301,"assets":{"audio":[{"id":"9d5a3553-ecf9-4463-938f-92a86670ae36","mode":"stop","asset":"caa99cda-776d-4bc0-a80d-72f0326f648a","delay":0},{"id":"d8898202-51d6-431a-a9fc-081d963e977b","mode":"loop","asset":"58b381d9-d28c-4c8a-8a38-a8bc42ff0e96","delay":0}],"cover":{"id":"7981bafc-4fcc-4780-99c8-99bd95c293d7"}},"height":182,"outputs":["59c12c7d-a290-4264-a9fe-086ff970b102"],"autoHeight":true,"components":["7fb5bc29-b329-43d1-8102-4c81983c2f28"],"content":"<p>The festival is buzzing with energy. Street performers, colorful lights, and the smell of amazing food fill the air. Maya grabs your hand and pulls you toward the main stage.<\/p>","title":"<p>Street Festival<\/p>"},"84acacdc-3ecf-4aeb-80f9-ed3f370cd765":{"x":11660,"y":11220,"theme":"orange","width":301,"assets":{"cover":{"id":"b6f13187-fd33-415a-828f-38343a856f98"}},"height":161,"outputs":["1376d465-54bd-4fda-adde-a9a2231aed33"],"autoHeight":true,"components":[],"content":"<p>As the credits roll, you feel completely refreshed. Jake was right - sometimes the best cure for a tough week is good friends and simple pleasures.<\/p>","title":null},"8691d97d-1476-43c6-8ca1-b8daabe0ee09":{"x":11920,"y":12160,"theme":"blue","width":301,"assets":{"cover":{"id":"b6f13187-fd33-415a-828f-38343a856f98"}},"height":487,"outputs":["559939e2-76a5-43d1-a9bb-eb2e842c13ba"],"autoHeight":true,"components":["5e87633a-d1f5-40bf-b084-c5220a15ad97","7fb5bc29-b329-43d1-8102-4c81983c2f28"],"content":"<p><em>Looking at your friends - Maya finally relaxed, Jake quietly satisfied - you realize you've stumbled onto something important. <\/em><\/p><p><em>Maybe the best decisions aren't about choosing sides, but about finding ways to honor different needs. This feels... right.<\/em><\/p>","title":null},"8724f807-2aab-436d-b8c0-b1a81eba3321":{"x":10900,"y":11320,"theme":"orange","width":301,"assets":{"cover":{"id":"b6f13187-fd33-415a-828f-38343a856f98"}},"height":224,"outputs":["28699c0d-c12a-43cd-b106-a0cdf953dd1d","98d5ea37-573b-4ca2-8ce6-c586b6b48eda"],"autoHeight":true,"components":[],"content":"<p>The contrast is striking - an hour ago you were stressed about exams, now you're completely relaxed. But part of you wonders if you're missing out on something by playing it safe. Is this contentment, or are you just avoiding life?<\/p>","title":null},"98ef227a-39b2-4aff-83f3-280aa85c9465":{"x":10420,"y":12180,"theme":"blue","width":301,"assets":{"cover":{"id":"b6f13187-fd33-415a-828f-38343a856f98"}},"height":161,"outputs":["29933839-35bd-49e2-b772-9fdd250729b2"],"autoHeight":true,"components":[],"content":"<p>And now Jake's cozy setup feels like the perfect way to wind down. Maya curls up on the other end of the couch, surprisingly content.<\/p>","title":null},"aa7603c6-9af8-409b-90a2-3be46d2c0058":{"x":9800,"y":11300,"theme":"orange","width":301,"assets":{"audio":[{"id":"511e2767-4601-4a65-a9b2-d8e9f83ef5f6","mode":"loop","asset":"588547a5-1c12-41bb-9596-2712de1dcf24","delay":0},{"id":"546ab55f-89ec-4961-bac4-ebaa8be8b62e","mode":"stop","asset":"caa99cda-776d-4bc0-a80d-72f0326f648a","delay":0}],"cover":{"id":"b6f13187-fd33-415a-828f-38343a856f98"}},"height":182,"outputs":["8c25dfcb-ba21-4509-93f7-8917927f14f7"],"autoHeight":true,"components":[],"content":"<p>Jake's living room is the perfect retreat. Soft lighting, warm blankets, and the opening credits of an intriguing space adventure. You sink into the couch with a satisfied sigh.<\/p>","title":"<p>Cozy Evening<\/p>"},"abb0f32e-b35f-4271-b631-5f0860fddd42":{"x":7200,"y":11260,"theme":"cyan","width":321,"assets":{"cover":{"id":"7801bdd7-f722-44d4-9a4b-d1d16e048586"}},"height":399,"outputs":["4ab6a842-4a58-4144-babb-fe76bee42ae0"],"autoHeight":true,"components":["ad3d9699-c9ea-4bc0-aa9f-e9656ca0791c","894c2a71-952e-45c9-b55a-340794307a1d"],"content":"<p>As you step outside, Maya and Jake are waiting for you with very different expressions on their faces.<\/p>","title":null},"b39f2325-9701-4efb-afdb-c52fdb814b62":{"x":10920,"y":12200,"theme":"blue","width":301,"assets":{"cover":{"id":"b6f13187-fd33-415a-828f-38343a856f98"}},"height":205,"outputs":["0ff0c333-9e2b-4a95-a62d-72710ae660ac"],"autoHeight":true,"components":["7fb5bc29-b329-43d1-8102-4c81983c2f28"],"content":"<p><strong>Maya:<\/strong> \"Okay, I admit it. This combo was genius.\" <\/p>","title":null},"b86e0913-7076-474c-98c3-39eaca433d90":{"x":13240,"y":10960,"theme":"cyan","width":301,"assets":{"audio":[{"id":"f0fed97f-7726-4196-ad25-422596d6b640","mode":"stop","asset":"58b381d9-d28c-4c8a-8a38-a8bc42ff0e96","delay":0},{"id":"da4d2b24-3bb3-4b40-8a92-aede17177ccf","mode":"stop","asset":"588547a5-1c12-41bb-9596-2712de1dcf24","delay":0},{"id":"c5fb1173-ff34-4fcd-80a8-6999afa4a52d","mode":"loop","asset":"f489449a-b7ec-4a5a-b099-8badf2f51eea","delay":0}],"cover":{"id":"46dc1dc5-cb59-4f8a-99dd-52632bdb26b0"}},"height":395,"outputs":["c4560a2e-1fed-478e-9935-6393902ce8e0"],"autoHeight":true,"components":["1f4389b8-e21a-4d12-84c7-c36cc0c50345"],"content":"<blockquote><p>Whatever path you chose, you're reminded that good friends make any decision the right one.<\/p><\/blockquote>","title":"<p><\/p>"},"cb35db92-3c07-41bf-9c45-580ad6b891b4":{"x":6280,"y":11180,"theme":"cyan","width":341,"assets":{"audio":[{"id":"44dca8f3-c4bd-4620-a3dc-df78ebc95113","mode":"stop","asset":"f489449a-b7ec-4a5a-b099-8badf2f51eea","delay":0},{"id":"55a7b6f6-fcf2-45d5-ac13-b54769a823d9","mode":"loop","asset":"caa99cda-776d-4bc0-a80d-72f0326f648a","delay":0}],"cover":{"id":"310945cd-5e90-4af6-b7ba-ab269d123784"}},"height":529,"outputs":["51077c30-3bc3-427a-b1a1-8d6be26dc197"],"autoHeight":true,"components":["1f4389b8-e21a-4d12-84c7-c36cc0c50345"],"content":"<p><em>Finally! The last exam is over. <\/em><\/p><p>You pack your books, feeling both exhausted and relieved. <\/p>","title":"<p>Friday Afternoon<\/p>"},"d1f51111-4aaf-459b