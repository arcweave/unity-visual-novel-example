    - rid: 8697050763747131402
      type: {class: Element, ns: Arcweave.Project, asm: Assembly-CSharp}
      data:
        <Id>k__BackingField: 35533a31-2b6e-4cf2-9bf9-a904836fc398
        <Pos>k__BackingField: {x: 7640, y: 11240}
        <Title>k__BackingField: <p>Maya's Invitation</p>
        <RawContent>k__BackingField: <p><strong>Maya:</strong> "Alex! Perfect timing!
          There's this amazing street festival downtown tonight. Live music, food
          trucks, the works! We should totally go!"</p>
        <RuntimeContent>k__BackingField: 
        <ColorTheme>k__BackingField: cyan
        <Components>k__BackingField:
        - rid: 8697050763747131399
        <Attributes>k__BackingField: []
        <cover>k__BackingField:
          <type>k__BackingField: 1
          <filePath>k__BackingField: school.png
        <AudioAssets>k__BackingField: []
        <Outputs>k__BackingField:
        - <Id>k__BackingField: 7c41bd83-ae2c-4ff0-b06d-5293676935c3
          <RawLabel>k__BackingField: 
          <RuntimeLabel>k__BackingField: 
          <Source>k__BackingField:
            rid: 8697050763747131402
          <Target>k__BackingField:
            rid: 8697050763747131403
    - rid: 8697050763747131403
      type: {class: Element, ns: Arcweave.Project, asm: Assembly-CSharp}
      data:
        <Id>k__BackingField: 714a2e99-b0e7-4b7f-b4fd-7fcebc821e05
        <Pos>k__BackingField: {x: 8080, y: 11240}
        <Title>k__BackingField: <p>Jake's Invitation</p>
        <RawContent>k__BackingField: <p><strong>Jake:</strong> "Or... we could have
          a chill movie marathon at my place. I got that new sci-fi series everyone's
          talking about. Pizza, comfy couch, no crowds."</p>
        <RuntimeContent>k__BackingField: 
        <ColorTheme>k__BackingField: cyan
        <Components>k__BackingField:
        - rid: 8697050763747131398
        <Attributes>k__BackingField: []
        <cover>k__BackingField:
          <type>k__BackingField: 1
          <filePath>k__BackingField: school.png
        <AudioAssets>k__BackingField: []
        <Outputs>k__BackingField:
        - <Id>k__BackingField: d1c1c0ad-fe9d-467b-aee5-d885fdb0a82c
          <RawLabel>k__BackingField: 
          <RuntimeLabel>k__BackingField: 
          <Source>k__BackingField:
            rid: 8697050763747131403
          <Target>k__BackingField:
            rid: 8697050763747131404
    - rid: 8697050763747131404
      type: {class: Element, ns: Arcweave.Project, asm: Assembly-CSharp}
      data:
        <Id>k__BackingField: 5d00bdb7-a34f-49e5-ad42-a7373f72f7f0
        <Pos>k__BackingField: {x: 8540, y: 11300}
        <Title>k__BackingField: 
        <RawContent>k__BackingField: <p>You look between your two friends, each offering
          exactly what they love most. After this exhausting week, what do you really
          need?</p>
        <RuntimeContent>k__BackingField: 
        <ColorTheme>k__BackingField: cyan
        <Components>k__BackingField: []
        <Attributes>k__BackingField: []
        <cover>k__BackingField:
          <type>k__BackingField: 1
          <filePath>k__BackingField: school.png
        <AudioAssets>k__BackingField: []
        <Outputs>k__BackingField:
        - <Id>k__BackingField: 520395c4-13c3-44ce-b9e2-edca4d8818c6
          <RawLabel>k__BackingField: <p>"The festival sounds exciting! Count me in,
            Maya."</p>
          <RuntimeLabel>k__BackingField: 
          <Source>k__BackingField:
            rid: 8697050763747131404
          <Target>k__BackingField:
            rid: 8697050763747131405
        - <Id>k__BackingField: bb8a62f6-111f-445f-bb20-cd7d99407510
          <RawLabel>k__BackingField: <p>"Actually, Jake's idea sounds perfect after
            this week."</p>
          <RuntimeLabel>k__BackingField: 
          <Source>k__BackingField:
            rid: 8697050763747131404
          <Target>k__BackingField:
            rid: 8697050763747131406
        - <Id>k__BackingField: 1ae4f4ff-af0c-4eec-8dbe-c4512de310de
          <RawLabel>k__BackingField: <p>"Why don't we compromise? Festival first,
            then movies?"</p>
          <RuntimeLabel>k__BackingField: 
          <Source>k__BackingField:
            rid: 8697050763747131404
          <Target>k__BackingField:
            rid: 8697050763747131407
    - rid: 8697050763747131405
      type: {class: Element, ns: Arcweave.Project, asm: Assembly-CSharp}
      data:
        <Id>k__BackingField: 7886024f-0500-45ed-ba40-f917f91309ff
        <Pos>k__BackingField: {x: 9800, y: 10340}
        <Title>k__BackingField: <p>Street Festival</p>
        <RawContent>k__BackingField: <p>The festival is buzzing with energy. Street
